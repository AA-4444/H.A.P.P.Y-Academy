{
  "rewrites": [
    {
      "source": "/quiz",
      "destination": "https://compass-eta-rosy.vercel.app"
    },
    {
      "source": "/quiz/:path*",
      "destination": "https://compass-eta-rosy.vercel.app/:path*"
    },
    {
      "source": "/ua",
      "destination": "/ua/index.html"
    },
    {
      "source": "/ua/:path*",
      "destination": "/ua/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}